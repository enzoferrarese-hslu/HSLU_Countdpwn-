{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "includeFiles": "app/**",
      "excludeFiles": "{data/**,docs/**,tests/**,docker/**,**/__pycache__/**,*.db}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
